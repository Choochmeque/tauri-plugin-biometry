<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Preferences DataStore lives at files/datastore/<name>.preferences_pb,
             which maps to domain="file" in backup rules. -->
        <exclude domain="file" path="datastore/biometric_data.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/biometric_data.preferences_pb"/>
    </device-transfer>
</data-extraction-rules>
